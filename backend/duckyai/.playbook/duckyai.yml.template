version: "0.0.18"
id: ${vault_id}
name: ${vault_name}

user:
  name: "${user_name}"
  primaryLanguage: ${primary_language}
  timezone: "${timezone}"

services:
  path: "${services_path}"
  entries: []

orchestrator:
  auto_start: true
  prompts_dir: .github/prompts-agent
  skills_dir: .github/skills
  max_concurrent: 3
  poll_interval: 1
  log_level: INFO
  log_retention_days: 30
  file_extensions:
  - .md
  - .pdf
  - .docx
  - .doc
  - .txt
  use_container: ${use_container}
  container:
    image: duckyai-agent:latest
defaults:
  executor: copilot_sdk
  timeout_minutes: 30
  max_parallel: 3
  task_create: true
  task_priority: medium
  task_archived: false
  agent_params:
    model: ${model}

nodes:
- type: agent
  name: Teams Chat Summary (TCS)
  cron: "${tcs_cron}"
  output_path: 04-Periodic/Daily
  output_type: update_file
  requires_input_file: false
  max_parallel: 1
  enabled: ${tcs_enabled}
  use_container: false
  agent_params:
    lookback_hours: 24

- type: agent
  name: Teams Meeting Summary (TMS)
  cron: "${tms_cron}"
  output_path: 04-Periodic/Daily
  output_type: update_file
  requires_input_file: false
  max_parallel: 1
  enabled: ${tms_enabled}
  use_container: false
  agent_params:
    lookback_hours: 24

- type: agent
  name: Task Manager (TM)
  trigger_wait_for: [ TCS, TMS ]
  require_parent_output: true
  output_path: 04-Periodic/Daily
  output_type: update_file
  requires_input_file: false
  enabled: true
  use_container: false
  agent_params:
    model: claude-haiku-4.5

- type: agent
  name: Task Planner (TP)
  input_type: manual
  output_type: update_file
  output_optional: true
  max_parallel: 1
  timeout_minutes: 30
  use_container: ${use_container}
  extra_mounts:
  - source: "${services_path}"
    target: "/services"
  enabled: true

- type: agent
  name: PR Review (PR)
  input_path: 01-Work/PRReviews
  output_type: update_file
  input_type: new_file
  input_pattern: "*.md"
  trigger_content_pattern: "^status:\\s*todo"
  requires_input_file: true
  max_parallel: 3
  enabled: true
  use_container: ${use_container}
  extra_mounts:
  - source: "${services_path}"
    target: "/services"
    readonly: true
  - source: "${repo_cache}"
    target: "/repo-cache"
    readonly: false

- type: agent
  name: PR Scan (PRS)
  cron: "15 */2 * * *"
  output_path: 01-Work/PRReviews
  output_type: new_file
  use_container: ${use_container}
  extra_mounts:
  - source: "${services_path}"
    target: "/services"
    readonly: true

- type: agent
  name: Service Sync (SVC)
  requires_input_file: false
  max_parallel: 1
  enabled: true
  use_container: false
