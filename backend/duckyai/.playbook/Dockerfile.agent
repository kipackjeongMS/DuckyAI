# DuckyAI Agent Runtime Image
# Contains all executor runtimes (Claude CLI, Copilot CLI/SDK, Azure CLI)
# Used by the orchestrator to run agents in isolated ephemeral containers.
#
# Build:  docker build -f Dockerfile.agent -t duckyai-agent:latest .
# Usage:  docker run --rm -i -v /path/to/vault:/vault duckyai-agent:latest claude --print ...

FROM python:3.12-slim AS base

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 20 (for Copilot CLI, Claude CLI) ──
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Azure CLI ──
RUN curl -sL https://aka.ms/InstallAzureCLIDeb | bash \
    && rm -rf /var/lib/apt/lists/*

# ── Claude CLI (npm global) ──
RUN npm install -g @anthropic-ai/claude-code@latest

# ── Copilot CLI (npm global) ──
RUN npm install -g @anthropic-ai/copilot@latest 2>/dev/null || true
# Note: Copilot CLI may not be publicly available on npm.
# If installed locally on host, mount ~/.copilot into the container instead.

# ── MCP servers (npm global) ──
RUN npm install -g @microsoft/workiq

# ── DuckyAI (from GitHub release) ──
ARG DUCKYAI_VERSION=latest
RUN set -ex && \
    if [ "$DUCKYAI_VERSION" = "latest" ]; then \
        DUCKYAI_URL="https://api.github.com/repos/kipackjeongMS/DuckyAI/releases/latest"; \
    else \
        DUCKYAI_URL="https://api.github.com/repos/kipackjeongMS/DuckyAI/releases/tags/${DUCKYAI_VERSION}"; \
    fi && \
    TARBALL=$(curl -sL "$DUCKYAI_URL" | python3 -c "import sys,json; print(json.load(sys.stdin).get('tarball_url',''))") && \
    if [ -z "$TARBALL" ]; then \
        echo "Could not resolve release tarball — installing from git HEAD" && \
        pip install --no-cache-dir "git+https://github.com/kipackjeongMS/DuckyAI.git#subdirectory=backend"; \
    else \
        mkdir -p /tmp/duckyai-src && \
        curl -sL "$TARBALL" | tar xz -C /tmp/duckyai-src --strip-components=1 && \
        pip install --no-cache-dir /tmp/duckyai-src/backend && \
        rm -rf /tmp/duckyai-src; \
    fi

# ── Container marker ──
ENV DUCKYAI_CONTAINER=1

# Default working directory (vault mount point)
WORKDIR /vault

# No entrypoint — command is passed per `docker run`
