{
  "name": "@duckyai/electron",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && concurrently -k -n vite,electron \"vite\" \"cross-env ELECTRON_IS_DEV=1 electron .\"",
    "build": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:all": "npm run build && npm run build:electron",
    "start": "npm run build:all && electron .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@duckyai/shared": "*",
    "@github/copilot-sdk": "^0.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "yaml": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "jsdom": "^26.1.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.6.0",
    "vite": "6.3.5",
    "vitest": "^3.2.1"
  }
}
