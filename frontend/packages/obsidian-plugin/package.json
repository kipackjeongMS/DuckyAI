{
  "name": "@duckyai/obsidian-plugin",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build:css": "npx @tailwindcss/cli -i src/styles.css -o styles.css --minify",
    "build:js": "node esbuild.config.mjs production",
    "build": "npm run build:css && npm run build:js",
    "deploy": "npm run build && node -e \"const fs=require('fs'),p=require('path'),vault=p.resolve('C:/Users/kipackjeong/Main/.obsidian/plugins/duckyai');fs.mkdirSync(vault,{recursive:true});['main.js','manifest.json','styles.css'].forEach(f=>fs.copyFileSync(f,p.join(vault,f)));console.log('Deployed to',vault)\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@duckyai/shared": "*",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "jsdom": "^26.1.0",
    "obsidian": "^1.7.2",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.1"
  }
}
